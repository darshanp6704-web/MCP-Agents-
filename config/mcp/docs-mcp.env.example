# Google Docs MCP Server configuration template
# Copy to docs-mcp.env and populate with Google Cloud API credentials

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=1//your-oauth2-refresh-token
# The target Google Doc ID to write to (can also be configured per product)
# TARGET_DOCUMENT_ID=your-shared-google-doc-id
